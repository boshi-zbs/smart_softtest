<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smarttestplatform.module.operationlog.mapper.OperationLogMapper">

    <resultMap id="BaseResultMap" type="com.example.smarttestplatform.module.operationlog.entity.OperationLog">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="username" column="username"/>
        <result property="module" column="module"/>
        <result property="operation" column="operation"/>
        <result property="description" column="description"/>
        <result property="targetId" column="target_id"/>
        <result property="requestParams" column="request_params"/>
        <result property="result" column="result"/>
        <result property="ipAddress" column="ip_address"/>
        <result property="userAgent" column="user_agent"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT * FROM operation_log
        <where>
            <if test="conditions.username != null and conditions.username != ''">
                AND username LIKE CONCAT('%', #{conditions.username}, '%')
            </if>
            <if test="conditions.module != null and conditions.module != ''">
                AND module = #{conditions.module}
            </if>
            <if test="conditions.operation != null and conditions.operation != ''">
                AND operation = #{conditions.operation}
            </if>
            <if test="conditions.startTime != null">
                AND create_time >= #{conditions.startTime}
            </if>
            <if test="conditions.endTime != null">
                AND create_time &lt;= #{conditions.endTime}
            </if>
        </where>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM operation_log
        <where>
            <if test="conditions.username != null and conditions.username != ''">
                AND username LIKE CONCAT('%', #{conditions.username}, '%')
            </if>
            <if test="conditions.module != null and conditions.module != ''">
                AND module = #{conditions.module}
            </if>
            <if test="conditions.operation != null and conditions.operation != ''">
                AND operation = #{conditions.operation}
            </if>
            <if test="conditions.startTime != null">
                AND create_time >= #{conditions.startTime}
            </if>
            <if test="conditions.endTime != null">
                AND create_time &lt;= #{conditions.endTime}
            </if>
        </where>
    </select>

</mapper>