<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smarttestplatform.module.testplan.mapper.TestPlanMapper">

    <resultMap id="BaseResultMap" type="com.example.smarttestplatform.module.testplan.entity.TestPlan">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="planName" column="plan_name"/>
        <result property="description" column="description"/>
        <result property="startDate" column="start_date"/>
        <result property="endDate" column="end_date"/>
        <result property="status" column="status"/>
        <result property="creatorId" column="creator_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="assigneeId" column="assignee_id"/>
    </resultMap>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT tp.*, u.real_name as assignee_name
        FROM test_plan tp
        LEFT JOIN user u ON tp.assignee_id = u.id
        <where>
            <if test="conditions.projectId != null">
                AND tp.project_id = #{conditions.projectId}
            </if>
            <if test="conditions.planName != null and conditions.planName != ''">
                AND tp.plan_name LIKE CONCAT('%', #{conditions.planName}, '%')
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND tp.status = #{conditions.status}
            </if>
            <!-- 权限过滤：非管理员只显示自己负责的计划 -->
            <if test="conditions.currentUserId != null and conditions.role != 'ROLE_ADMIN'">
                AND tp.assignee_id = #{conditions.currentUserId}
            </if>
        </where>
        ORDER BY tp.id DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM test_plan tp
        <where>
            <if test="conditions.projectId != null">
                AND tp.project_id = #{conditions.projectId}
            </if>
            <if test="conditions.planName != null and conditions.planName != ''">
                AND tp.plan_name LIKE CONCAT('%', #{conditions.planName}, '%')
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND tp.status = #{conditions.status}
            </if>
            <!-- 权限过滤：非管理员只显示自己负责的计划 -->
            <if test="conditions.currentUserId != null and conditions.role != 'ROLE_ADMIN'">
                AND tp.assignee_id = #{conditions.currentUserId}
            </if>
        </where>
    </select>

</mapper>