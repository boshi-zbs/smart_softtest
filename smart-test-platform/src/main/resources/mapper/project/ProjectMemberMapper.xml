<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smarttestplatform.module.project.mapper.ProjectMemberMapper">

    <resultMap id="BaseResultMap" type="com.example.smarttestplatform.module.project.entity.ProjectMember">
        <result property="projectId" column="project_id"/>
        <result property="userId" column="user_id"/>
        <result property="roleInProject" column="role_in_project"/>
        <result property="joinTime" column="join_time"/>
    </resultMap>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT * FROM project_member
        <where>
            <if test="conditions.projectId != null">
                AND project_id = #{conditions.projectId}
            </if>
            <if test="conditions.roleInProject != null and conditions.roleInProject != ''">
                AND role_in_project = #{conditions.roleInProject}
            </if>
        </where>
        ORDER BY join_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM project_member
        <where>
            <if test="conditions.projectId != null">
                AND project_id = #{conditions.projectId}
            </if>
            <if test="conditions.roleInProject != null and conditions.roleInProject != ''">
                AND role_in_project = #{conditions.roleInProject}
            </if>
        </where>
    </select>

</mapper>