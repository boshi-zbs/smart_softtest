<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smarttestplatform.module.requirement.mapper.RequirementMapper">

    <resultMap id="BaseResultMap" type="com.example.smarttestplatform.module.requirement.entity.Requirement">
        <id property="id" column="id"/>
        <result property="projectId" column="project_id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="priority" column="priority"/>
        <result property="status" column="status"/>
        <result property="assigneeId" column="assignee_id"/>
        <result property="creatorId" column="creator_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT * FROM requirement
        <where>
            <if test="conditions.projectId != null">
                AND project_id = #{conditions.projectId}
            </if>
            <if test="conditions.title != null and conditions.title != ''">
                AND title LIKE CONCAT('%', #{conditions.title}, '%')
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND status = #{conditions.status}
            </if>
            <if test="conditions.priority != null">
                AND priority = #{conditions.priority}
            </if>
            <if test="conditions.assigneeId != null">
                AND assignee_id = #{conditions.assigneeId}
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM requirement
        <where>
            <if test="conditions.projectId != null">
                AND project_id = #{conditions.projectId}
            </if>
            <if test="conditions.title != null and conditions.title != ''">
                AND title LIKE CONCAT('%', #{conditions.title}, '%')
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND status = #{conditions.status}
            </if>
            <if test="conditions.priority != null">
                AND priority = #{conditions.priority}
            </if>
            <if test="conditions.assigneeId != null">
                AND assignee_id = #{conditions.assigneeId}
            </if>
        </where>
    </select>
    <select id="countByProjectIds" resultType="int">
        SELECT COUNT(*) FROM requirement
        WHERE project_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>