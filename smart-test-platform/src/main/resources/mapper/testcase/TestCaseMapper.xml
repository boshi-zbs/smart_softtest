<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smarttestplatform.module.testcase.mapper.TestCaseMapper">

    <resultMap id="BaseResultMap" type="com.example.smarttestplatform.module.testcase.entity.TestCase">
        <id property="id" column="id"/>
        <result property="requirementId" column="requirement_id"/>
        <result property="projectId" column="project_id"/>
        <result property="moduleId" column="module_id"/>
        <result property="title" column="title"/>
        <result property="precondition" column="precondition"/>
        <result property="steps" column="steps"/>
        <result property="expectedResult" column="expected_result"/>
        <result property="priority" column="priority"/>
        <result property="type" column="type"/>
        <result property="status" column="status"/>
        <result property="creatorId" column="creator_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT tc.* FROM test_case tc
        <if test="conditions.planId != null">
            INNER JOIN plan_case pc ON tc.id = pc.case_id
        </if>
        <where>
            <if test="conditions.planId != null">
                AND pc.plan_id = #{conditions.planId}
            </if>
            <if test="conditions.moduleId != null">
                AND tc.module_id = #{conditions.moduleId}
            </if>
            <if test="conditions.title != null and conditions.title != ''">
                AND tc.title LIKE CONCAT('%', #{conditions.title}, '%')
            </if>
            <if test="conditions.type != null and conditions.type != ''">
                AND tc.type = #{conditions.type}
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND tc.status = #{conditions.status}
            </if>
            <if test="conditions.priority != null">
                AND tc.priority = #{conditions.priority}
            </if>
            <if test="conditions.requirementId != null">
                AND tc.requirement_id = #{conditions.requirementId}
            </if>
        </where>
        ORDER BY tc.id DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM test_case tc
        <if test="conditions.planId != null">
            INNER JOIN plan_case pc ON tc.id = pc.case_id
        </if>
        <where>
            <if test="conditions.planId != null">
                AND pc.plan_id = #{conditions.planId}
            </if>
            <if test="conditions.moduleId != null">
                AND tc.module_id = #{conditions.moduleId}
            </if>
            <if test="conditions.title != null and conditions.title != ''">
                AND tc.title LIKE CONCAT('%', #{conditions.title}, '%')
            </if>
            <if test="conditions.type != null and conditions.type != ''">
                AND tc.type = #{conditions.type}
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND tc.status = #{conditions.status}
            </if>
            <if test="conditions.priority != null">
                AND tc.priority = #{conditions.priority}
            </if>
            <if test="conditions.requirementId != null">
                AND tc.requirement_id = #{conditions.requirementId}
            </if>
        </where>
    </select>

    <select id="findByIds" resultMap="BaseResultMap">
        SELECT * FROM test_case WHERE id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="countByProjectIds" resultType="int">
        SELECT COUNT(DISTINCT tc.id) FROM test_case tc
        LEFT JOIN plan_case pc ON tc.id = pc.case_id
        LEFT JOIN test_plan tp ON pc.plan_id = tp.id
        WHERE tp.project_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>
</mapper>