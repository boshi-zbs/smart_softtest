<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smarttestplatform.module.defect.mapper.DefectMapper">

    <resultMap id="BaseResultMap" type="com.example.smarttestplatform.module.defect.entity.Defect">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="severity" column="severity"/>
        <result property="priority" column="priority"/>
        <result property="status" column="status"/>
        <result property="reporterId" column="reporter_id"/>
        <result property="assigneeId" column="assignee_id"/>
        <result property="testCaseId" column="test_case_id"/>
        <result property="requirementId" column="requirement_id"/>
        <result property="projectId" column="project_id"/>
        <result property="foundVersion" column="found_version"/>
        <result property="fixedVersion" column="fixed_version"/>
        <result property="autoExecutionId" column="auto_execution_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT * FROM defect
        <where>
            <if test="conditions.projectId != null">
                AND project_id = #{conditions.projectId}
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND status = #{conditions.status}
            </if>
            <if test="conditions.severity != null and conditions.severity != ''">
                AND severity = #{conditions.severity}
            </if>
            <if test="conditions.priority != null and conditions.priority != ''">
                AND priority = #{conditions.priority}
            </if>
            <if test="conditions.reporterId != null">
                AND reporter_id = #{conditions.reporterId}
            </if>
            <if test="conditions.assigneeId != null">
                AND assignee_id = #{conditions.assigneeId}
            </if>
            <if test="conditions.title != null and conditions.title != ''">
                AND title LIKE CONCAT('%', #{conditions.title}, '%')
            </if>
        </where>
        ORDER BY id DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM defect
        <where>
            <if test="conditions.projectId != null">
                AND project_id = #{conditions.projectId}
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND status = #{conditions.status}
            </if>
            <if test="conditions.severity != null and conditions.severity != ''">
                AND severity = #{conditions.severity}
            </if>
            <if test="conditions.priority != null and conditions.priority != ''">
                AND priority = #{conditions.priority}
            </if>
            <if test="conditions.reporterId != null">
                AND reporter_id = #{conditions.reporterId}
            </if>
            <if test="conditions.assigneeId != null">
                AND assignee_id = #{conditions.assigneeId}
            </if>
            <if test="conditions.title != null and conditions.title != ''">
                AND title LIKE CONCAT('%', #{conditions.title}, '%')
            </if>
        </where>
    </select>

    <select id="countByProjectIds" resultType="int">
        SELECT COUNT(*) FROM defect
        WHERE project_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <select id="countOpenByProjectIds" resultType="int">
        SELECT COUNT(*) FROM defect
        WHERE project_id IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        AND status IN ('新建', '已指派', '修复中')
    </select>

    <select id="findRecentByProjectIds" resultMap="BaseResultMap">
        SELECT * FROM defect
        WHERE project_id IN
        <foreach collection="projectIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY create_time DESC LIMIT #{limit}
    </select>

    <select id="countByCreateDateRange" resultType="map">
        SELECT DATE(create_time) as date, COUNT(*) as count FROM defect
        WHERE project_id IN
        <foreach collection="projectIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        AND create_time >= DATE_SUB(NOW(), INTERVAL #{days} DAY)
        GROUP BY DATE(create_time) ORDER BY date
    </select>

    <select id="countByProjectIdsAndStatus" resultType="map">
        SELECT status, COUNT(*) as count FROM defect
        WHERE project_id IN
        <foreach collection="projectIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        GROUP BY status
    </select>

    <select id="findAssignedToUser" resultType="map">
        SELECT d.*, u.real_name as reporterName FROM defect d
        LEFT JOIN user u ON d.reporter_id = u.id
        WHERE d.assignee_id = #{userId} AND d.status IN ('新建', '已指派', '修复中')
        ORDER BY d.create_time DESC
        <if test="limit != null">LIMIT #{limit}</if>
    </select>

</mapper>