<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.smarttestplatform.module.autotest.mapper.AutoTestExecutionMapper">

    <resultMap id="BaseResultMap" type="com.example.smarttestplatform.module.autotest.entity.AutoTestExecution">
        <id property="id" column="id"/>
        <result property="caseId" column="case_id"/>
        <result property="executorId" column="executor_id"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="status" column="status"/>
        <result property="result" column="result"/>
        <result property="ip" column="ip"/>
        <result property="screenshotUrl" column="screenshot_url"/>
    </resultMap>

    <select id="pageQuery" resultMap="BaseResultMap">
        SELECT * FROM auto_test_execution
        <where>
            <if test="conditions.caseId != null">
                AND case_id = #{conditions.caseId}
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND status = #{conditions.status}
            </if>
        </where>
        ORDER BY start_time DESC
        LIMIT #{offset}, #{size}
    </select>

    <select id="count" resultType="long">
        SELECT COUNT(*) FROM auto_test_execution
        <where>
            <if test="conditions.caseId != null">
                AND case_id = #{conditions.caseId}
            </if>
            <if test="conditions.status != null and conditions.status != ''">
                AND status = #{conditions.status}
            </if>
        </where>
    </select>

</mapper>